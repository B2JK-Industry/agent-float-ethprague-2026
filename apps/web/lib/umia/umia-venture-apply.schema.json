{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://yourapp.com/schemas/umia-venture-apply.schema.json",
  "title": "UmiaCommunityTrackApplication",
  "description": "Canonical payload emitted by our app for future integration with `umia venture apply`. This is not an official Umia CLI schema. Required fields are based on public Umia documentation; optional fields capture reasonable future launch preferences.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "target_command",
    "submission_track",
    "team",
    "owner_contacts",
    "project"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1.0",
      "description": "Version of our app-owned integration payload."
    },
    "target_command": {
      "type": "string",
      "const": "umia venture apply",
      "description": "Future Umia CLI command this payload is designed to map to."
    },
    "submission_track": {
      "type": "string",
      "const": "community",
      "description": "The Community Track is the only documented permissionless CLI application path."
    },
    "project": {
      "type": "object",
      "description": "Core project identity and public proof of work as collected from the UI.",
      "additionalProperties": false,
      "required": [
        "name",
        "description",
        "pitch",
        "stage",
        "links"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 2,
          "maxLength": 80,
          "description": "Project name."
        },
        "description": {
          "type": "string",
          "minLength": 50,
          "maxLength": 2000,
          "description": "What the project is building and why it matters."
        },
        "pitch": {
          "type": "string",
          "minLength": 10,
          "maxLength": 500,
          "description": "Short pitch used in the application UI."
        },
        "stage": {
          "type": "string",
          "enum": [
            "Idea",
            "Pre-MVP",
            "MVP",
            "Customers",
            "Revenue",
            "Growth"
          ],
          "description": "Current project stage from the UI."
        },
        "links": {
          "type": "object",
          "description": "Links collected by the UI.",
          "additionalProperties": false,
          "required": [
            "github_repositories"
          ],
          "properties": {
            "website": {
              "type": "string",
              "format": "uri"
            },
            "github_repositories": {
              "type": "array",
              "description": "GitHub repositories required by the Community Track docs.",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "format": "uri",
                "pattern": "^https://github\\.com/[^/]+/[^/]+/?$"
              }
            },
            "github_organization": {
              "type": "string",
              "format": "uri"
            },
            "docs": {
              "type": "string",
              "format": "uri"
            },
            "demo": {
              "type": "string",
              "format": "uri"
            },
            "twitter": {
              "type": "string",
              "format": "uri"
            },
            "telegram": {
              "type": "string",
              "format": "uri"
            },
            "discord": {
              "type": "string",
              "format": "uri"
            },
            "other": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "label",
                  "url"
                ],
                "properties": {
                  "label": {
                    "type": "string"
                  },
                  "url": {
                    "type": "string",
                    "format": "uri"
                  }
                }
              }
            }
          }
        },
        "traction_metrics": {
          "type": "object",
          "description": "Optional traction signals that may help Umia or future curation markets evaluate the project.",
          "additionalProperties": false,
          "properties": {
            "monthly_revenue_usd": {
              "type": "number",
              "minimum": 0
            },
            "monthly_active_users": {
              "type": "integer",
              "minimum": 0
            },
            "github_stars": {
              "type": "integer",
              "minimum": 0
            },
            "github_forks": {
              "type": "integer",
              "minimum": 0
            },
            "other": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "label",
                  "value"
                ],
                "properties": {
                  "label": {
                    "type": "string"
                  },
                  "value": {
                    "type": [
                      "string",
                      "number",
                      "integer"
                    ]
                  }
                }
              }
            }
          }
        }
      }
    },
    "team": {
      "type": "object",
      "description": "Team members collected by the UI.",
      "additionalProperties": false,
      "required": [
        "members"
      ],
      "properties": {
        "members": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "role"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "handle": {
                "type": "string",
                "description": "Optional pseudonymous handle."
              },
              "role": {
                "type": "string",
                "enum": [
                  "Founder",
                  "Investor",
                  "Advisor",
                  "Researcher",
                  "Ambassador",
                  "Other"
                ]
              },
              "wallet_address": {
                "type": "string",
                "pattern": "^0x[a-fA-F0-9]{40}$"
              },
              "github": {
                "type": "string"
              },
              "twitter": {
                "type": "string"
              },
              "bio": {
                "type": "string",
                "maxLength": 500
              }
            }
          }
        }
      }
    },
    "owner_contacts": {
      "type": "array",
      "description": "Owner contact methods collected by the UI for follow-up and onboarding.",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": [
              "Founder",
              "Investor",
              "Advisor",
              "Researcher",
              "Ambassador",
              "Other"
            ]
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "telegram": {
            "type": "string",
            "minLength": 2
          },
          "twitter": {
            "type": "string",
            "minLength": 2
          },
          "discord": {
            "type": "string",
            "minLength": 2
          },
          "phone": {
            "type": "string",
            "minLength": 5
          },
          "wallet_address": {
            "type": "string",
            "pattern": "^0x[a-fA-F0-9]{40}$"
          },
          "preferred_contact": {
            "type": "string",
            "enum": [
              "email",
              "telegram",
              "twitter",
              "discord",
              "phone"
            ]
          }
        },
        "anyOf": [
          {
            "required": [
              "email"
            ]
          },
          {
            "required": [
              "telegram"
            ]
          },
          {
            "required": [
              "twitter"
            ]
          },
          {
            "required": [
              "discord"
            ]
          },
          {
            "required": [
              "phone"
            ]
          }
        ]
      }
    },
    "submission_notes": {
      "type": "string",
      "maxLength": 2000,
      "description": "Internal notes for the eventual Umia adapter layer."
    }
  }
}
