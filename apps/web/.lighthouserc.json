{
  "ci": {
    "collect": {
      "startServerCommand": "pnpm dev",
      "url": [
        "http://localhost:3000/r/vault.upgrade-siren-demo.eth?mock=true",
        "http://localhost:3000/demo"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "error",
          { "minScore": 0.9 }
        ]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
