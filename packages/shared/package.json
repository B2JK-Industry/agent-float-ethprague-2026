{
  "name": "@upgrade-siren/shared",
  "version": "0.0.0",
  "private": true,
  "description": "Shared types, schema, and primitives for Upgrade Siren.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schemas/siren-report-v1.json": "./schemas/siren-report-v1.json"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./schemas/siren-report-v1.json": "./schemas/siren-report-v1.json"
    }
  },
  "files": [
    "src",
    "dist",
    "schemas"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "viem": "^2.21.55"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
